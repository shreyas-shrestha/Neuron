SECRET_KEY=replace-with-openssl-rand-hex-32
# Docker Compose (repo root): required for backend service — same value as SECRET_KEY or a dedicated hex key.
# NEURON_SECRET_KEY=generate-with-python-secrets-token-hex-32
# Optional. If unset, SQLite uses backend/neuron.db (path fixed to the backend package, not cwd).
# DATABASE_URL=sqlite:///./custom.db

# Plain-English flag explanations via local Ollama (langchain-ollama). Set OLLAMA_EXPLAIN_ENABLED=false to skip.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3
# OLLAMA_EXPLAIN_ENABLED=true

# Optional: for local SDK demos (sdk/demo_retraining_narrative.py; pip install -e ".[demo]" from sdk/). Copy to .env — never commit .env.
# Create a key in the app: Settings → API Keys → Generate.
NEURON_API_KEY=nrn_replace_with_key_from_settings

# Optional: queue heavy analysis jobs (HookedTransformer) outside the API process.
# pip install -e ".[worker]" then: celery -A app.workers.celery_app worker --loglevel=info
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Optional: presigned S3 PUT for large checkpoints (SDK). pip install -e ".[s3]"
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ARTIFACTS_BUCKET=your-bucket
