SECRET_KEY=replace-with-openssl-rand-hex-32
# Optional. If unset, SQLite uses backend/neuron.db (path fixed to the backend package, not cwd).
# DATABASE_URL=sqlite:///./custom.db

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: for local SDK demos (sdk/demo_retraining_narrative.py; pip install -e ".[demo]" from sdk/). Copy to .env — never commit .env.
# Create a key in the app: Settings → API Keys → Generate.
NEURON_API_KEY=nrn_replace_with_key_from_settings
